local plr = game.Players.LocalPlayer
local vim = game:GetService("VirtualInputManager")

print("Load")
local Character = player.Character or player.CharacterAdded:Wait() 

game.Loaded:Wait()
print("GO!")
local hiding = false
local connecteds = {}

local function lookAtTarget(targetPosition)
    local camera = workspace.CurrentCamera
    local character = plr.Character
    
    local headPosition = character:FindFirstChild("Head") and character.Head.Position or character.PrimaryPart.Position
    local direction = (targetPosition - headPosition).Unit
    
    camera.CFrame = CFrame.lookAt(headPosition, targetPosition)
end

local function getCurrentRoom()
    local current_room = workspace.GameData.CurrentRoom.Value
    if not current_room then
        
        if workspace.CurrentRooms:FindFirstChild("0") then return workspace.CurrentRooms["0"] end
        return nil
    end

    return current_room
end

local function playerHasKeycard()
    if plr.Backpack:FindFirstChild("Keycard") then
        return true
    end
    
    if plr.Character and plr.Character:FindFirstChild("Keycard") then
        return true
    end
    
    return false
end 

local function click_center()
    local screenSize = workspace.CurrentCamera.ViewportSize
    local centerX, centerY = screenSize.X / 2, screenSize.Y / 2
    
    vim:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    vim:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
end

local function open_door() 

    local currentRooms = workspace.CurrentRooms
    local rooms = currentRooms:GetChildren()
    local room = rooms[#rooms-1]

    local door
    local door_proxi: ProximityPrompt
    if room:FindFirstChild("Door") then

        door = room.Door
        for _, i in ipairs(door:GetDescendants()) do
            if i.Name == "KeycardScanner" then
                door_proxi = i.Screen1.Hold
            end
        end
    elseif room:FindFirstChild("Door50Gate") then
        door = room.Door50Gate
    end

    if not playerHasKeycard() then
        for _, i:Part in ipairs(room:GetDescendants()) do

            if i.Name == "KillBlock" then
                
                plr.Character.PrimaryPart.CFrame = i:GetPivot()
                break
            end

            if i.Name == "Keycard" and i:FindFirstChildWhichIsA("ProximityPrompt") then
                
                print("Нашел ключ-карту:", i)
                plr.Character.PrimaryPart.CFrame = i:GetPivot() * CFrame.new(6, 0, 6)

                local proxi:ProximityPrompt = i:FindFirstChildWhichIsA("ProximityPrompt")
                proxi.Enabled = true
                proxi.HoldDuration = 0
                proxi.MaxActivationDistance = 10000
                
                lookAtTarget(i:GetPivot().Position)

                local conn = proxi.PromptShown:Connect(function()
                    fireproximityprompt(proxi)
                end)
                table.insert(connecteds, conn)

                repeat 
                    
                    plr.Character.PrimaryPart.CFrame = i:GetPivot() * CFrame.new(6, 0, 6)
                    lookAtTarget(i:GetPivot().Position) 
                    fireproximityprompt(proxi) 
                    task.wait(0.5)
                until playerHasKeycard()
                
                conn:Disconnect()
                task.wait(1)
            end
        end
    end

    plr.Character.PrimaryPart.CFrame = door:GetPivot()
    task.wait(0.4)

    if door_proxi then
        lookAtTarget(door_proxi.Parent.Position)
        door_proxi.HoldDuration = 0
        fireproximityprompt(door_proxi)
    end
end

